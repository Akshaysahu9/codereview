{
  "name": "codereview",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-language static code review platform",
  "scripts": {
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --port 8000",
    "build": "npm run build --prefix frontend",
    "install:all": "npm install --prefix frontend && cd backend && pip install -r requirements.txt"
  }
}
